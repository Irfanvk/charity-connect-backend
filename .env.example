# Backend Configuration - Copy to .env and update values

# Application Settings
DEBUG=False
APP_NAME=Charity Connect Backend
APP_VERSION=1.0.0

# Database Configuration
# Local development: postgresql://postgres:password@localhost:5432/charity_connect
# Production (Heroku): postgres://user:pass@host:port/dbname
DATABASE_URL=postgresql://charity_user:password@localhost:5432/charity_connect

# JWT Settings - Generate strong SECRET_KEY for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# File Upload
MAX_UPLOAD_SIZE_MB=3
UPLOAD_DIR=./app/uploads

# CORS Configuration
# Development: ["http://localhost:3000", "http://127.0.0.1:3000"]
# Production: ["https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Logging
LOG_LEVEL=INFO
