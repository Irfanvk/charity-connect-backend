# Backend Configuration - Copy to .env and update values

# Application Settings
DEBUG=False
APP_NAME=CharityHub Backend
APP_VERSION=1.0.0

# Database Configuration
# Local development: postgresql://postgres:password@localhost:5432/charity_connect
# Production (Heroku): postgres://user:pass@host:port/dbname
DATABASE_URL=postgresql://charity_user:password@localhost:5432/charity_connect

# JWT Settings - Generate strong SECRET_KEY for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# File Upload
MAX_UPLOAD_SIZE_MB=3
UPLOAD_DIR=./app/uploads

# Cloudinary file storage (uploads, avatars, payment proofs)
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=charity-connect

# Frontend base URL — used to build invite registration links in WhatsApp messages etc.
# MUST be set to your production domain, e.g. https://poyyathabailgcc.netlify.app
FRONTEND_BASE_URL=https://your-frontend-domain.netlify.app

# CORS Configuration - comma-separated list of allowed origins
# Development: http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# Production: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TIMEZONE=UTC
ENABLE_FASTAPI_LIMITER=false

# ── Web Push (required for closed-app push notifications) ────────────────────
# 1. Generate VAPID keys (one-time, keep them forever):
#      pip install py-vapid
#      python -m py_vapid --gen
#    This writes private_key.pem and public_key.pem in the current directory.
#
# 2. LOCAL DEV — point WEB_PUSH_PRIVATE_KEY at the file:
#      WEB_PUSH_PRIVATE_KEY=E:/CharityHub/charity-connect-backend/private_key.pem
#
# 3. PRODUCTION (Render) — encode the PEM as base64 (no multiline env var needed):
#      python -c "import base64,pathlib; print(base64.b64encode(pathlib.Path('private_key.pem').read_bytes()).decode())"
#    Paste the output as the value of WEB_PUSH_PRIVATE_KEY in Render dashboard.
#    The backend auto-detects file path vs base64 vs raw PEM.
#
# 4. Copy the URL-safe base64 public key from public_key.pem (Application Server Key)
#    and paste it as VITE_WEB_PUSH_PUBLIC_KEY in the Netlify environment variables too.
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@charityhub.app
# ─────────────────────────────────────────────────────────────────────────────

# Import Defaults - Password for newly imported members
IMPORT_DEFAULT_PASSWORD=TempPassword123!
